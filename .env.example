# fast-embed local configuration
# Copy to .env: cp .env.example .env

# Servidor (127.0.0.1 para dev local, 0.0.0.0 para Docker)
BIND_ADDRESS=127.0.0.1:11435
LOG_LEVEL=info

# Modelos
DEFAULT_EMBED_MODEL=nomic-embed-text-v1.5
MODEL_CACHE_DIR=./models
HF_TOKEN=

# Base de datos
DB_PATH=./data/inference.db

# Seguridad
ADMIN_KEY_HASH=

# Rate limiting (opcionales — si no se setean, se calculan del hardware)
# OVERRIDE_MAX_CONCURRENT=8
# OVERRIDE_MAX_PER_MINUTE=60
